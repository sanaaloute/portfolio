# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=portfolio

# Backend auth
JWT_SECRET=change-me-to-a-long-random-string-min-32-characters
ADMIN_PASSWORD=your-secure-admin-password
# For production, generate a bcrypt hash and use ADMIN_PASSWORD_HASH instead:
# ADMIN_PASSWORD_HASH=$2b$12$...

# CORS — for prod compose use http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# Optional OpenAI key for chat polish
OPENAI_API_KEY=
