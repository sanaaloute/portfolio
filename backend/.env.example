# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/portfolio

# Auth
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
# Either set a plaintext password (dev only) or a bcrypt hash (recommended for production).
ADMIN_PASSWORD=your-secure-admin-password
# ADMIN_PASSWORD_HASH=$2b$12$...

# CORS — comma-separated origins, or "*" for any
CORS_ORIGINS=*

# Optional: enables LLM polish in /api/chat/query
OPENAI_API_KEY=
