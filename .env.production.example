# Production environment template. Copy to .env on the server and fill in REAL secrets.
# NEVER commit the filled-in .env (it is gitignored).

# --- PostgreSQL ---------------------------------------------------------------
# POSTGRES_PASSWORD: use LETTERS AND DIGITS ONLY. Special characters (/, #, %, &, @)
# break DATABASE_URL parsing — the backend dies with "Name or service not known".
# Generate with:  openssl rand -hex 24
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=portfolio

# --- Backend auth -------------------------------------------------------------
# Generate with:  openssl rand -hex 32   (must be >= 32 chars, not a placeholder)
JWT_SECRET=change-me-32-plus-random-hex-chars

# Prefer the bcrypt HASH over the plaintext password in production.
# 1) Set the password you want to use here temporarily:
ADMIN_PASSWORD=
# 2) Generate its hash on the server (after the backend image is built):
#    docker compose run --rm -T backend \
#      python -m app.security 'YourStrongPassword'
# 3) Paste the hash below with EVERY '$' DOUBLED ($$) — Compose interpolates '$' in .env,
#    so '$2b$12$…' must be written as '$$2b$$12$$…' or login will 500. Then clear ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=

# --- CORS / cookies -----------------------------------------------------------
# The exact browser origin of the site (scheme + host). Same-origin via the host nginx,
# but keep it correct. For HTTPS (recommended):
CORS_ORIGINS=https://aloutesana.ai-web-builder.com
# true behind HTTPS (nginx + certbot). Set false ONLY if serving plain HTTP.
COOKIE_SECURE=true

# --- Host port ----------------------------------------------------------------
# Localhost-only port the backend is published on for the host nginx. Change if
# another container on the host already uses 8000. The deploy scripts render
# nginx-portfolio.conf proxy_pass to match automatically.
# BACKEND_HOST_PORT=8000

# --- Prebuilt images (ECR pull mode; optional) --------------------------------
# Leave commented to BUILD on the instance. To PULL from ECR instead, set it to
# your ECR URI (see DEPLOY.md "CI/CD with ECR") and run `pull` then `up -d`.
# BACKEND_IMAGE=123456789012.dkr.ecr.eu-west-1.amazonaws.com/portfolio-backend:latest
