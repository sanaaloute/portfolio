# Production environment template. Copy to .env on the server and fill in REAL secrets.
# NEVER commit the filled-in .env (it is gitignored).

# --- PostgreSQL ---------------------------------------------------------------
# POSTGRES_PASSWORD: use LETTERS AND DIGITS ONLY. Special characters (/, #, %, &, @)
# break DATABASE_URL parsing — the backend dies with "Name or service not known".
# Generate with:  openssl rand -hex 24
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=portfolio

# --- Backend auth -------------------------------------------------------------
# Generate with:  openssl rand -hex 32   (must be >= 32 chars, not a placeholder)
JWT_SECRET=change-me-32-plus-random-hex-chars

# Set your admin password here BEFORE deploying (letters, digits and -_!. only —
# no $, #, %, &, spaces or quotes). The deploy scripts automatically hash it with
# bcrypt into ADMIN_PASSWORD_HASH and CLEAR this value during deployment, so the
# plaintext only exists transiently. To rotate later: set it again, run update.sh.
ADMIN_PASSWORD=
# Managed automatically by deploy/secure-admin-password.sh — do not edit by hand.
ADMIN_PASSWORD_HASH=

# --- CORS / cookies -----------------------------------------------------------
# The exact browser origin of the site (scheme + host). Same-origin via the host nginx,
# but keep it correct. For HTTPS (recommended):
CORS_ORIGINS=https://aloutesana.ai-web-builder.com
# true behind HTTPS (nginx + certbot). Set false ONLY if serving plain HTTP.
COOKIE_SECURE=true

# --- Host port ----------------------------------------------------------------
# Localhost-only port the web container is published on for the host nginx.
# Change if another container on the host already uses 8081. The deploy scripts
# render nginx-portfolio.conf proxy_pass to match automatically.
# WEB_HOST_PORT=8081

